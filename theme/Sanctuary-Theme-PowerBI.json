                "valueAxis": [{
                    "fontFamily": "Segoe UI",
                    "fontSize": 10,
                    "labelColor": {"solid": {"color": "#605e5c"}}
                }]
            },
            "card": {
                "calloutValue": [{
                    "fontFamily": "Segoe UI Semibold",
