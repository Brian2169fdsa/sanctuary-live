{
    "name": "Sanctuary Recovery Centers",
    "dataColors": [
        "#e8732a", "#4dc8e8", "#f5a623", "#107c10",
        "#d83b01", "#3aa8c8", "#986f0b", "#605e5c"
    ],
    "background": "#ffffff",
